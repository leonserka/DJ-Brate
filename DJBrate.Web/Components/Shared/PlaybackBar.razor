@implements IAsyncDisposable
@using DJBrate.Web.Services
@using Microsoft.JSInterop
@inject PlaybackState State
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="player-bar @(State.PlayingTrackId is null ? "player-bar-hidden" : "")">
    <div class="player-bar-inner">
        <div class="player-now-playing">
            @if (State.CurrentTrack is { } cur)
            {
                @if (ShowGoToPlaylistButton)
                {
                    <button type="button" class="player-nav-btn player-goto-btn"
                            @onclick="GoToPlaylist"
                            aria-label="Open playing playlist"
                            title="Open playing playlist">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                            <path d="M3 5h12v2H3V5zm0 4h12v2H3V9zm0 4h8v2H3v-2zm14-2 6 4-6 4v-8z"/>
                        </svg>
                    </button>
                }
                @if (!string.IsNullOrEmpty(cur.AlbumImageUrl))
                {
                    <img src="@cur.AlbumImageUrl" alt="" class="player-art" />
                }
                else
                {
                    <div class="player-art player-art-placeholder">&#9835;</div>
                }
                <div class="player-track-info">
                    <div class="player-track-name">@cur.TrackName</div>
                    <div class="player-track-artist">@cur.ArtistName</div>
                </div>
            }
        </div>

        <div class="player-center">
            <div class="player-controls">
                <button type="button" class="player-nav-btn"
                        @onclick="State.PlayPreviousAsync"
                        disabled="@(!State.CanPlayPrevious)"
                        aria-label="Previous track">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                        <path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/>
                    </svg>
                </button>
                <button type="button" class="player-play-btn"
                        @onclick="State.TogglePlayPauseAsync"
                        aria-label="@(State.IsPaused ? "Play" : "Pause")">
                    @if (State.IsPaused)
                    {
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                            <path d="M7 5.14v13.72c0 .79.87 1.27 1.54.84l10.8-6.86a1 1 0 0 0 0-1.68L8.54 4.3A1 1 0 0 0 7 5.14z"/>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                            <rect x="6" y="5" width="4" height="14" rx="1"/>
                            <rect x="14" y="5" width="4" height="14" rx="1"/>
                        </svg>
                    }
                </button>
                <button type="button" class="player-nav-btn"
                        @onclick="State.PlayNextAsync"
                        disabled="@(!State.CanPlayNext)"
                        aria-label="Next track">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                        <path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/>
                    </svg>
                </button>
            </div>

            <div class="player-progress">
                <span class="player-time">@FormatTime(State.PositionMs)</span>
                <input type="range" class="player-progress-bar"
                       min="0" max="@(State.DurationMs > 0 ? State.DurationMs : 1)"
                       value="@State.PositionMs"
                       style="--progress: @ProgressPercent%"
                       @onchange="OnSeek" />
                <span class="player-time">@FormatTime(State.DurationMs)</span>
            </div>
        </div>
    </div>
</div>

@code {
    private IJSObjectReference? _module;
    private DotNetObjectReference<PlaybackBar>? _selfRef;

    protected override void OnInitialized()
    {
        State.OnChange += HandleStateChange;
        Nav.LocationChanged += HandleLocationChanged;
    }

    private void HandleStateChange() => InvokeAsync(StateHasChanged);

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/preview-watcher.js");
        _selfRef = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("init", _selfRef);

        State.PlayInvoker = trackId => _module.InvokeVoidAsync("play", trackId).AsTask();
        State.TogglePlayInvoker = () => _module.InvokeVoidAsync("togglePlay").AsTask();
        State.SeekInvoker = ms => _module.InvokeVoidAsync("seek", ms).AsTask();
    }

    [JSInvokable]
    public Task OnPlaybackUpdate(double position, double duration, bool paused)
    {
        State.UpdatePlayback(position, duration, paused);
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnPreviewEnded() => State.HandleTrackEndedAsync();

    private async Task OnSeek(ChangeEventArgs e)
    {
        if (!double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var ms)) return;
        await State.SeekAsync(ms);
    }

    private void GoToPlaylist()
    {
        if (State.SourcePlaylistId is { } id) Nav.NavigateTo($"/playlists/{id}");
    }

    private bool ShowGoToPlaylistButton
    {
        get
        {
            if (State.SourcePlaylistId is null) return false;
            var current = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
            return !current.Equals($"playlists/{State.SourcePlaylistId}", StringComparison.OrdinalIgnoreCase);
        }
    }

    private string ProgressPercent =>
        State.DurationMs > 0
            ? (State.PositionMs / State.DurationMs * 100).ToString("F2", System.Globalization.CultureInfo.InvariantCulture)
            : "0";

    private static string FormatTime(double ms)
    {
        if (double.IsNaN(ms) || ms < 0) ms = 0;
        var totalSeconds = (int)(ms / 1000);
        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;
        return $"{minutes}:{seconds:D2}";
    }

    public async ValueTask DisposeAsync()
    {
        State.OnChange -= HandleStateChange;
        Nav.LocationChanged -= HandleLocationChanged;
        State.PlayInvoker = null;
        State.TogglePlayInvoker = null;
        State.SeekInvoker = null;
        if (_module is not null)
        {
            var disposeTask = _module.InvokeVoidAsync("dispose").AsTask();
            await disposeTask.ConfigureAwait(ConfigureAwaitOptions.SuppressThrowing);
            var moduleDispose = _module.DisposeAsync().AsTask();
            await moduleDispose.ConfigureAwait(ConfigureAwaitOptions.SuppressThrowing);
        }
        _selfRef?.Dispose();
    }
}
